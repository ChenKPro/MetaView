<Window x:Class="MetaView.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:core="clr-namespace:MetaView.Presentation.Core"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="MeataView-Evo Concept Workstation"
        Width="1680"
        Height="980"
        MinWidth="1360"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>
    <Grid Background="{StaticResource BrushBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0"
                        prism:RegionManager.RegionName="{x:Static core:RegionNames.TopBarRegion}" />

        <Grid Grid.Row="1" Margin="10,8,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="224" />
                <ColumnDefinition Width="1.42*" />
                <ColumnDefinition Width="354" />
                <ColumnDefinition Width="366" />
            </Grid.ColumnDefinitions>

            <ContentControl Grid.Column="0"
                            Margin="0,0,8,0"
                            prism:RegionManager.RegionName="{x:Static core:RegionNames.NavigationRegion}" />
            <ContentControl Grid.Column="1"
                            Margin="0,0,8,0"
                            prism:RegionManager.RegionName="{x:Static core:RegionNames.WorkspaceRegion}" />
            <ContentControl Grid.Column="2"
                            Margin="0,0,8,0"
                            prism:RegionManager.RegionName="{x:Static core:RegionNames.HardwareRegion}" />
            <ContentControl Grid.Column="3"
                            prism:RegionManager.RegionName="{x:Static core:RegionNames.AcquisitionRegion}" />
        </Grid>

        <ContentControl Grid.Row="2"
                        Margin="10,0,10,0"
                        prism:RegionManager.RegionName="{x:Static core:RegionNames.StatusRegion}" />
    </Grid>
</Window>

