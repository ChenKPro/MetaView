<UserControl x:Class="MetaView.Presentation.Views.ImageWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MetaView.Presentation.Controls"
             xmlns:plot="clr-namespace:Vibronix.Presentation.Wpf.Plot.Views;assembly=Vibronix.Presentation.Wpf.Plot"
             xmlns:viewer="clr-namespace:ImageViewer2D.Controls;assembly=ImageViewer2D.Controls">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MetaView.Presentation;component/Themes/PresentationResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="ImageModeTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{StaticResource BrushHeaderChrome}"
                                    BorderBrush="{StaticResource BrushLine}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,0,14,0">
                                <DockPanel LastChildFill="False">
                                    <Grid DockPanel.Dock="Left"
                                          VerticalAlignment="Center"
                                          Margin="0,0,16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="3"
                                                Height="22"
                                                Background="#5AAEFF"
                                                CornerRadius="2"
                                                Opacity="0.9" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Image Display"
                                                   Foreground="{StaticResource BrushText}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <Border DockPanel.Dock="Right"
                                            VerticalAlignment="Bottom"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,-1,0,-1"
                                            Width="580">
                                        <TabPanel x:Name="HeaderPanel"
                                                  IsItemsHost="True"
                                                  KeyboardNavigation.TabIndex="1"
                                                  Panel.ZIndex="1"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                                    </Border>
                                </DockPanel>
                            </Border>
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ImageModeTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Width" Value="124" />
            <Setter Property="MinWidth" Value="124" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,4,1,0" />
            <Setter Property="Panel.ZIndex" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Chrome"
                                Background="#16232D"
                                BorderBrush="{StaticResource BrushLine}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="5,5,0,0">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Border x:Name="TopLight"
                                        Height="1"
                                        Margin="4,0"
                                        VerticalAlignment="Top"
                                        Background="#FFFFFF"
                                        Opacity="0.06" />
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Panel.ZIndex" Value="5" />
                                <Setter TargetName="Chrome" Property="Background" Value="#1B2D39" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4C7897" />
                                <Setter TargetName="TopLight" Property="Opacity" Value="0.16" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="20" />
                                <Setter TargetName="Chrome" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#65B8F1" Offset="0" />
                                            <GradientStop Color="#2E78AA" Offset="0.55" />
                                            <GradientStop Color="#1A3B52" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#6BBFFF" />
                                <Setter TargetName="TopLight" Property="Opacity" Value="0.32" />
                                <Setter Property="Foreground" Value="#F2F2F2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#16212A" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#263E52" />
                                <Setter Property="Foreground" Value="#D3E1ED" />
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AnalysisToggleRadioButton" TargetType="CheckBox">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="8,0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Grid Width="16"
                                      Height="16"
                                      Margin="0,0,7,0">
                                    <Ellipse Fill="#F3F6F8"
                                             Stroke="#5D6B75"
                                             StrokeThickness="1" />
                                    <Ellipse x:Name="Dot"
                                             Width="7"
                                             Height="7"
                                             Fill="#1F2B35"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Opacity="0" />
                                </Grid>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="#F2F2F2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ImageModeComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Width" Value="164" />
            <Setter Property="MinWidth" Value="164" />
            <Setter Property="Margin" Value="0,4,1,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#16232D" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushLine}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0">
                            <Grid>
                                <Border x:Name="TopLight"
                                        Height="1"
                                        Margin="16,0"
                                        VerticalAlignment="Top"
                                        Background="#FFFFFF"
                                        Opacity="0.06" />
                                <ToggleButton x:Name="PART_DropDownToggle"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press">
                                    <Grid Margin="{TemplateBinding Padding}">
                                        <TextBlock Text="{TemplateBinding SelectionBoxItem}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontWeight="{TemplateBinding FontWeight}" />
                                        <Path Width="7"
                                              Height="4"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Fill="{TemplateBinding Foreground}"
                                              Data="M 0 0 L 7 0 L 3.5 4 Z" />
                                    </Grid>
                                </ToggleButton>
                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       PopupAnimation="Fade">
                                    <Border Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            Background="#16232D"
                                            BorderBrush="#4C7897"
                                            BorderThickness="1"
                                            CornerRadius="0,0,5,5">
                                        <ScrollViewer CanContentScroll="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1B2D39" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4C7897" />
                                <Setter TargetName="TopLight" Property="Opacity" Value="0.16" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Chrome" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#65B8F1" Offset="0" />
                                            <GradientStop Color="#2E78AA" Offset="0.55" />
                                            <GradientStop Color="#1A3B52" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#6BBFFF" />
                                <Setter TargetName="TopLight" Property="Opacity" Value="0.32" />
                                <Setter Property="Foreground" Value="#F2F2F2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ImageModeComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Height" Value="28" />
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1B2D39" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2E78AA" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0" />
            <RowDefinition Height="2.32*" />
            <RowDefinition Height="0.82*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2" Style="{StaticResource PanelBorder}" Padding="0" ClipToBounds="True" Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource BrushHeaderChrome}"
                        BorderBrush="{StaticResource BrushLine}"
                        BorderThickness="0,0,0,1"
                        Padding="12,0,14,0">
                    <DockPanel LastChildFill="False">
                        <Grid DockPanel.Dock="Left"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="3"
                                    Height="22"
                                    Background="#5AAEFF"
                                    CornerRadius="2"
                                    Opacity="0.9" />
                            <TextBlock Grid.Column="1"
                                       Text="Image Display"
                                       Foreground="{StaticResource BrushText}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom"
                                    Margin="0,-1,0,-1">
                            <ComboBox ItemsSource="{Binding WorkspaceViews}"
                                      SelectedItem="{Binding SelectedView}"
                                      ItemContainerStyle="{StaticResource ImageModeComboBoxItem}"
                                      Style="{StaticResource ImageModeComboBox}" />
                            <Border Width="58"
                                    Height="32"
                                    Margin="0,4,1,0"
                                    Background="#16232D"
                                    BorderBrush="{StaticResource BrushLine}"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="5,5,0,0"
                                    Cursor="Hand"
                                    PreviewMouseLeftButtonDown="ToggleImageToolBar">
                                <TextBlock Text="&gt;&gt;"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource BrushMuted}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <viewer:ImageViewer2D x:Name="ImageViewer"
                                          Source="{Binding LiveImageSource}"
                                          ShowNavigator="True"
                                          ShowToolBar="{Binding IsImageToolBarOpen, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          RoiStroke="{StaticResource BrushCyan}"
                                          RoiStrokeThickness="2"
                                          ImageMouseDown="OnImageMouseDown"
                                          ImageMouseMove="OnImageMouseMove"
                                          ImageMouseUp="OnImageMouseUp"
                                          ImageMouseDoubleClick="OnImageMouseDoubleClick"
                                          ImageMouseWheel="OnImageMouseWheel" />
                    <StackPanel HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="18,0,0,16">
                        <Border Width="86"
                                Height="4"
                                Background="#F1F6FA"
                                CornerRadius="2"
                                HorizontalAlignment="Left" />
                        <TextBlock Text="20 um"
                                   Style="{StaticResource HudValue}"
                                   HorizontalAlignment="Left"
                                   Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        BorderBrush="{StaticResource BrushLine}"
                        BorderThickness="0,1,0,0"
                        Background="#E417222B"
                        Padding="12,0">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Pixel 0.43 um" Foreground="{StaticResource BrushMuted}" Margin="0,0,18,0" />
                            <TextBlock Text="Image 86.42 um" Foreground="{StaticResource BrushMuted}" Margin="0,0,18,0" />
                            <TextBlock Text="FPS 1.18" Foreground="{StaticResource BrushMuted}" Margin="0,0,18,0" />
                            <TextBlock Text="Mouse  X 0.00 um  Y 0.00 um" Foreground="{StaticResource BrushMuted}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Mouse ROI 200 x 200 px" Style="{StaticResource HudValue}" Margin="0,0,18,0" />
                            <TextBlock Text="ROI adjusted" Foreground="{StaticResource BrushMuted}" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="0" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border BorderBrush="{StaticResource BrushLine}" BorderThickness="0,0,0,1" Padding="10,0" Background="{StaticResource BrushHeaderChrome}">
                    <DockPanel LastChildFill="False">
                        <Grid DockPanel.Dock="Left" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="3" Height="22" Background="#5AAEFF" CornerRadius="2" Opacity="0.9" />
                            <TextBlock Grid.Column="1"
                                       Text="Analysis"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Signal" IsChecked="{Binding ShowSignalPanel}" Style="{StaticResource AnalysisToggleRadioButton}" />
                            <CheckBox Content="Histogram" IsChecked="{Binding ShowHistogramPanel}" Style="{StaticResource AnalysisToggleRadioButton}" />
                            <CheckBox Content="AlgDetector" IsChecked="{Binding ShowContextPanel}" Style="{StaticResource AnalysisToggleRadioButton}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding SignalPanelWidth}" />
                        <ColumnDefinition Width="{Binding HistogramPanelWidth}" />
                        <ColumnDefinition Width="{Binding ContextPanelWidth}" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource BrushPanelInset}" BorderBrush="{StaticResource BrushLine}" BorderThickness="1" CornerRadius="4" Padding="5" Margin="0,0,4,0"
                            Visibility="{Binding SignalPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,2">
                        <TextBlock Text="SIGNAL" Style="{StaticResource AreaTitle}" Margin="0" DockPanel.Dock="Left" />
                        <TextBlock Text="2850 cm-1" Style="{StaticResource HudValue}" FontSize="11" DockPanel.Dock="Right" />
                    </DockPanel>
                    <Border Grid.Row="1"
                            Background="#151F28"
                            BorderBrush="{StaticResource BrushLine}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <plot:PlotView ChartId="{Binding SignalPlotChartId}" />
                    </Border>
                </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BrushPanelInset}" BorderBrush="{StaticResource BrushLine}" BorderThickness="1" CornerRadius="4" Padding="5" Margin="0,0,4,0"
                            Visibility="{Binding HistogramPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,2">
                        <TextBlock Text="HISTOGRAM" Style="{StaticResource AreaTitle}" Margin="0" DockPanel.Dock="Left" />
                        <TextBlock Text="Intensity" Style="{StaticResource HudValue}" FontSize="11" DockPanel.Dock="Right" />
                    </DockPanel>
                    <controls:RatioBox Grid.Row="1" AspectRatio="2.2">
                        <Canvas>
                            <Line X1="24" Y1="142" X2="420" Y2="142" Stroke="{StaticResource BrushLine}" />
                            <Rectangle Canvas.Left="48" Canvas.Top="82" Width="28" Height="60" Fill="#344553" />
                            <Rectangle Canvas.Left="98" Canvas.Top="54" Width="28" Height="88" Fill="#426D91" />
                            <Rectangle Canvas.Left="148" Canvas.Top="22" Width="28" Height="120" Fill="#4E8FC4" />
                            <Rectangle Canvas.Left="198" Canvas.Top="40" Width="28" Height="102" Fill="#5AAEFF" />
                            <Rectangle Canvas.Left="248" Canvas.Top="94" Width="28" Height="48" Fill="#344553" />
                            <Rectangle Canvas.Left="298" Canvas.Top="114" Width="28" Height="28" Fill="#26333C" />
                        </Canvas>
                    </controls:RatioBox>
                </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource BrushPanelInset}" BorderBrush="{StaticResource BrushLine}" BorderThickness="1" CornerRadius="4" Padding="5"
                            Visibility="{Binding ContextPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,2">
                        <TextBlock Text="AlgDetector" Style="{StaticResource AreaTitle}" Margin="0" DockPanel.Dock="Left" />
                        <TextBlock Text="Ready" Style="{StaticResource HudValue}" FontSize="11" DockPanel.Dock="Right" />
                    </DockPanel>
                    <Grid Grid.Row="1" />
                </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</UserControl>



