<UserControl x:Class="MetaView.Presentation.Views.AcquisitionPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MetaView.Presentation.Controls">
    <UserControl.Resources>
        <Style x:Key="FeatureToggle" TargetType="CheckBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Chrome"
                                Background="#141F28"
                                BorderBrush="#263B4D"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel LastChildFill="True">
                                <Ellipse x:Name="Dot"
                                         DockPanel.Dock="Left"
                                         Width="7"
                                         Height="7"
                                         Fill="#365876"
                                         Margin="0,0,7,0" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4F8FBD" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1F3E5A" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#579ACF" />
                                <Setter TargetName="Dot" Property="Fill" Value="{StaticResource BrushReady}" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="StatusMetric" TargetType="Border">
            <Setter Property="Background" Value="#141F28" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushLine}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="QueueRow" TargetType="Border">
            <Setter Property="Height" Value="27" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#263E52" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="AdvancedGroup" TargetType="Border">
            <Setter Property="Background" Value="#111A21" />
            <Setter Property="BorderBrush" Value="#2E5671" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="SpectralCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorder}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource BrushHeaderChrome}"
                    BorderBrush="{StaticResource BrushLine}"
                    BorderThickness="0,0,0,1"
                    Padding="10,0">
                <DockPanel LastChildFill="False">
                    <Grid DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="3" Height="22" Background="#5AAEFF" CornerRadius="2" Opacity="0.9" />
                        <TextBlock Grid.Column="1"
                                   Text="Acquisition"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource ChipBorder}">
                            <TextBlock Text="{Binding StateText}" />
                        </Border>
                        <Border Style="{StaticResource ChipBorder}">
                            <TextBlock Text="SRS" />
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="{StaticResource BrushLine}"
                    BorderThickness="0,0,0,1"
                    Padding="8">
                <UniformGrid Columns="4">
                    <Button Content="Live"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LivePreviewCommand}"
                            Height="36"
                            Margin="0,0,6,0" />
                    <Button Content="Capture"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding SingleCaptureCommand}" />
                    <Button Content="Abort"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding AbortCommand}"
                            Height="36"
                            Margin="0,0,6,0" />
                    <Button Content="Demo"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding RunDemoWorkflowCommand}"
                            Height="36"
                            Margin="0" />
                </UniformGrid>
            </Border>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BrushLine}"
                    BorderThickness="0,0,0,1"
                    Padding="8">
                <StackPanel>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource StatusMetric}">
                            <StackPanel>
                                <TextBlock Text="Estimated" Style="{StaticResource HudLabel}" />
                                <TextBlock Text="00:12:30" Style="{StaticResource HudValue}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource StatusMetric}">
                            <StackPanel>
                                <TextBlock Text="Countdown" Style="{StaticResource HudLabel}" />
                                <TextBlock Text="00:09:48" Style="{StaticResource HudValue}" Foreground="{StaticResource BrushCyan}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatusMetric}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Progress" Style="{StaticResource HudLabel}" />
                                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource HudValue}" FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="46" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Height="8"
                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                     Maximum="100"
                                     Foreground="{StaticResource BrushCyan}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                                   Style="{StaticResource HudValue}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="6">
                <StackPanel>
                    <Border Style="{StaticResource SubtlePanel}" Margin="0,0,0,8" Padding="0">
                        <StackPanel>
                            <Border BorderBrush="{StaticResource BrushLine}" BorderThickness="0,0,0,1" Padding="8,7">
                                <TextBlock Text="Advanced" Style="{StaticResource SectionTitle}" FontSize="13" />
                            </Border>

                            <Border Padding="8">
                            <StackPanel>
                                <TextBlock Text="FEATURE" Style="{StaticResource AreaTitle}" Margin="0,0,0,5" />
                                <WrapPanel Margin="0,0,0,7">
                                    <CheckBox Content="Modal" IsChecked="{Binding UseModal}" />
                                    <CheckBox Content="Large Area" IsChecked="{Binding UseLargeArea}" />
                                    <CheckBox Content="3D Volume" IsChecked="{Binding Use3D}" />
                                    <CheckBox Content="Time Lapse" IsChecked="{Binding UseTimeLapse}" />
                                    <CheckBox Content="BBO Normalization" />
                                </WrapPanel>

                                <DockPanel LastChildFill="True" Margin="0,0,0,8">
                                    <TextBlock Text="Scan Sequence"
                                               DockPanel.Dock="Left"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrushText}"
                                               Margin="0,0,8,0" />
                                    <ComboBox SelectedIndex="0">
                                        <ComboBoxItem Content="Modal First" />
                                        <ComboBoxItem Content="Large Area First" />
                                        <ComboBoxItem Content="3D First" />
                                        <ComboBoxItem Content="Time First" />
                                    </ComboBox>
                                </DockPanel>

                                <Expander IsExpanded="True" Margin="0,0,0,6">
                                    <Expander.Header>
                                        <TextBlock Text="Multimodality" FontWeight="SemiBold" Foreground="{StaticResource BrushText}" />
                                    </Expander.Header>
                                    <Border Style="{StaticResource AdvancedGroup}" Padding="8">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                                <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <RadioButton Content="Sequential" IsChecked="True" />
                                                <RadioButton Content="Concurrent" />
                                                <TextBlock Text="In Use" Margin="12,0,8,0" VerticalAlignment="Center" />
                                                <Button Content="Select all" DockPanel.Dock="Right" Padding="10,3" />
                                            </DockPanel>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#151F28" BorderBrush="{StaticResource BrushLine}" BorderThickness="1" CornerRadius="3" Padding="8,5">
                                                    <TextBlock Text="Fwd-SRS_0" />
                                                </Border>
                                                <Button Grid.Column="1" Content="+" Margin="4,0,0,0" />
                                                <Button Grid.Column="2" Content="..." Margin="4,0,0,0" />
                                            </Grid>

                                            <UniformGrid Columns="2" Margin="0,0,0,6">
                                                <StackPanel Margin="0,0,6,0">
                                                    <TextBlock Text="PumpPower" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="NaN" />
                                                </StackPanel>
                                                <StackPanel Margin="6,0,0,0">
                                                    <TextBlock Text="StokesPower" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="NaN" />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,6,0">
                                                    <TextBlock Text="OffsetX" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="0" />
                                                </StackPanel>
                                                <StackPanel Margin="6,0,0,0">
                                                    <TextBlock Text="OffsetY" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="0" />
                                                </StackPanel>
                                            </UniformGrid>

                                            <CheckBox Content="Multi-Window Spectral" IsChecked="True" FontWeight="SemiBold" Margin="0,2,0,7" />

                                            <Border Background="#151F28" BorderBrush="{StaticResource BrushLine}" BorderThickness="1" CornerRadius="3" Padding="5">
                                                <StackPanel>
                                                    <UniformGrid Columns="2" Margin="0,0,0,5">
                                                        <TextBlock Text="HW (2700-3500 cm-1)" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Customer" HorizontalAlignment="Center" />
                                                        <TextBlock Text="LW (700-1800 cm-1)" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Silent (2000-2500 cm-1)" HorizontalAlignment="Center" />
                                                    </UniformGrid>

                                                    <Border BorderBrush="{StaticResource BrushLine}" BorderThickness="1" CornerRadius="3" Padding="0">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="30" />
                                                                <RowDefinition Height="27" />
                                                                <RowDefinition Height="27" />
                                                                <RowDefinition Height="27" />
                                                                <RowDefinition Height="27" />
                                                                <RowDefinition Height="27" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="24" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="46" />
                                                                <ColumnDefinition Width="46" />
                                                                <ColumnDefinition Width="62" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.ColumnSpan="5" Background="#1B2832" />
                                                            <TextBlock Grid.Column="1" Text="Window" Style="{StaticResource SpectralCell}" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="2" Text="Central" Style="{StaticResource SpectralCell}" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="3" Text="Pump" Style="{StaticResource SpectralCell}" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="4" Text="Timing" Style="{StaticResource SpectralCell}" FontWeight="SemiBold" />

                                                            <CheckBox Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="356-506" Style="{StaticResource SpectralCell}" Foreground="#FFB000" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="431" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="1" Grid.Column="3" Text="1000" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="1" Grid.Column="4" Text="20381-19731" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />

                                                            <CheckBox Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="436-586" Style="{StaticResource SpectralCell}" Foreground="#FFB000" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="511" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="2" Grid.Column="3" Text="992" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="2" Grid.Column="4" Text="20035-19385" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />

                                                            <CheckBox Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="500-700" Style="{StaticResource SpectralCell}" Foreground="#FFB000" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Row="3" Grid.Column="2" Text="604" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="3" Grid.Column="3" Text="983" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="3" Grid.Column="4" Text="19757-18891" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />

                                                            <CheckBox Grid.Row="4" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="600-770" Style="{StaticResource SpectralCell}" Foreground="#FFB000" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Row="4" Grid.Column="2" Text="698" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="4" Grid.Column="3" Text="974" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="4" Grid.Column="4" Text="19342-18618" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />

                                                            <CheckBox Grid.Row="5" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="720-910" Style="{StaticResource SpectralCell}" Foreground="#FFB000" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Row="5" Grid.Column="2" Text="815" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="5" Grid.Column="3" Text="963" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                            <TextBlock Grid.Row="5" Grid.Column="4" Text="18883-18079" Style="{StaticResource SpectralCell}" Foreground="#FFB000" />
                                                        </Grid>
                                                    </Border>

                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Substance" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" />
                                                        <ComboBox Grid.Column="1" SelectedIndex="0">
                                                            <ComboBoxItem Content="DMSO" />
                                                            <ComboBoxItem Content="Water" />
                                                            <ComboBoxItem Content="Custom" />
                                                        </ComboBox>
                                                        <CheckBox Grid.Column="2" Content="Overlap Optimize" Margin="8,0" />
                                                        <Button Grid.Column="3" Content="Next" MinWidth="58" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Expander>

                                <Expander IsExpanded="False" Margin="0,0,0,6">
                                    <Expander.Header>
                                        <TextBlock Text="LargeArea" FontWeight="SemiBold" Foreground="{StaticResource BrushText}" />
                                    </Expander.Header>
                                    <Border Style="{StaticResource AdvancedGroup}" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="Tile points and overlap setup" Style="{StaticResource HudLabel}" />
                                            <ListBox ItemsSource="{Binding LargeAreaPoints}" Height="70" />
                                        </StackPanel>
                                    </Border>
                                </Expander>

                                <Expander IsExpanded="False" Margin="0,0,0,6">
                                    <Expander.Header>
                                        <TextBlock Text="3D Volume" FontWeight="SemiBold" Foreground="{StaticResource BrushText}" />
                                    </Expander.Header>
                                    <Border Style="{StaticResource AdvancedGroup}" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="Z range and depth points" Style="{StaticResource HudLabel}" />
                                            <ListBox ItemsSource="{Binding DepthPoints}" Height="70" />
                                        </StackPanel>
                                    </Border>
                                </Expander>

                                <Expander IsExpanded="True">
                                    <Expander.Header>
                                        <TextBlock Text="Time Lapse" FontWeight="SemiBold" Foreground="{StaticResource BrushText}" />
                                    </Expander.Header>
                                    <Border Style="{StaticResource AdvancedGroup}" Padding="8">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Interval Time" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <ComboBox Grid.Column="1" SelectedIndex="0">
                                                    <ComboBoxItem Content="Second" />
                                                    <ComboBoxItem Content="Minute" />
                                                    <ComboBoxItem Content="Hour" />
                                                </ComboBox>
                                                <TextBox Grid.Column="2" Text="0" Margin="6,0,0,0" />
                                            </Grid>
                                            <WrapPanel>
                                                <CheckBox Content="Count" IsChecked="True" />
                                                <TextBox Text="0" Width="70" />
                                                <CheckBox Content="TotalTime" />
                                                <ComboBox Width="88" SelectedIndex="0">
                                                    <ComboBoxItem Content="Second" />
                                                    <ComboBoxItem Content="Minute" />
                                                </ComboBox>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Expander>
                            </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SubtlePanel}">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                <TextBlock Text="SAVE" Style="{StaticResource AreaTitle}" Margin="0" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding ValidationMessage}" Foreground="{StaticResource BrushCyan}" FontSize="11" />
                            </DockPanel>
                            <TextBlock Text="Save To" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding SavePath, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Save As" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding SaveName, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel>
                                <CheckBox Content="Auto Save" IsChecked="{Binding AutoSave}" />
                                <CheckBox Content="Raw Data" IsChecked="True" />
                                <CheckBox Content="Image Stack" IsChecked="True" />
                            </WrapPanel>

                            <Border Background="#101820"
                                    BorderBrush="{StaticResource BrushLine}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,8,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource QueueRow}">
                                        <Grid>
                                            <TextBlock Text="1. Live Tuning" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Text="Waiting" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource BrushMuted}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource QueueRow}">
                                        <Grid>
                                            <TextBlock Text="2. Test Capture" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Text="Waiting" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource BrushMuted}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource QueueRow}" BorderThickness="0">
                                        <Grid>
                                            <TextBlock Text="3. Save Raw + Image" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Text="Auto" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource BrushCyan}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>

