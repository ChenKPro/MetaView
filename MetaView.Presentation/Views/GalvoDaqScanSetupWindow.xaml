<Window x:Class="MetaView.Presentation.Views.GalvoDaqScanSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galvo / DAQ Scan Setup"
        Width="560"
        Height="760"
        WindowStartupLocation="CenterOwner"
        Background="#182530"
        Foreground="#EAF3FF">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#DDEAF6" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="0,2,0,5" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#0E1821" />
            <Setter Property="Foreground" Value="#F2F7FC" />
            <Setter Property="BorderBrush" Value="#2A536E" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="0,4,0,8" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Foreground" Value="#F2F7FC" />
            <Setter Property="Background" Value="#0E1821" />
            <Setter Property="BorderBrush" Value="#2A536E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="#A9BDCE"
                                                      Data="M 0 0 L 8 0 L 4 5 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4C83A9" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="12,0,38,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              RecognizesAccessKey="True" />
                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#0E1821"
                                        BorderBrush="#3A6685"
                                        BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#F2F7FC" />
            <Setter Property="Background" Value="#0E1821" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#234359" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2B5F82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#234359" />
            <Setter Property="Foreground" Value="#F2F7FC" />
            <Setter Property="BorderBrush" Value="#40759A" />
        </Style>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#DDEAF6" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4,0,6" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="#DDEAF6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupBox}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.RowSpan="2"
                                    Background="#111D27"
                                    BorderBrush="#27475E"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,9,0,0" />
                            <Border Grid.Row="0"
                                    Background="#182530"
                                    Padding="8,0"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left">
                                <ContentPresenter ContentSource="Header" />
                            </Border>
                            <ContentPresenter Grid.Row="1" Margin="14,10,14,12" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#111D27" />
            <Setter Property="BorderBrush" Value="#27475E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <TextBlock Text="Galvo / DAQ Scan Setup"
                       FontSize="22"
                       FontWeight="SemiBold"
                       DockPanel.Dock="Left" />
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#69B7FF"
                       HorizontalAlignment="Right" />
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Device and Channels">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="DAQ Type" />
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding DaqTypes}" SelectedItem="{Binding DaqType}" />
                        <TextBlock Grid.Row="1" Text="Device" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DeviceName, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="2" Text="AO1 X" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AoX, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="3" Text="AO2 Y" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding AoY, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="4" Text="AI0 X Position" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding AiX, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="5" Text="AI1 Y Position" />
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding AiY, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="6" Text="AI2 Signal A" />
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding AiSignalA, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="7" Text="AI3 Signal B" />
                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding AiSignalB, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="8" Text="Read XY Feedback" />
                        <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding ReadXYFeedback}" />
                        <TextBlock Grid.Row="9" Text="AI Terminal" />
                        <ComboBox Grid.Row="9" Grid.Column="1" ItemsSource="{Binding TerminalOptions}" SelectedItem="{Binding Terminal}" />
                        <TextBlock Grid.Row="10" Text="Voltage Min" />
                        <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding VoltageMinimum, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="11" Text="Voltage Max" />
                        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding VoltageMaximum, UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Synchronization">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="AO Clock Source" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AoClockSource, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="1" Text="AO Start Trigger" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding AoStartTriggerSource, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Scan Geometry">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Mode" />
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ScanModes}" SelectedItem="{Binding ScanMode}" />
                        <TextBlock Grid.Row="1" Text="Acquisition" />
                        <CheckBox Grid.Row="1" Grid.Column="1" Content="Continuous Refresh" IsChecked="{Binding Continuous}" />
                        <TextBlock Grid.Row="2" Text="Width" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ImageWidth, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="3" Text="Height" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ImageHeight, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="4" Text="X Extra Pixels" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding XExtraPixels, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="5" Text="Frames" />
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding FrameCount, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="6" Text="Sample Rate" />
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SampleRate, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="7" Text="Samples / Pixel" />
                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SamplesPerPixel, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="8" Text="X Center" />
                        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding CenterXVoltage, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="9" Text="Y Center" />
                        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding CenterYVoltage, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="10" Text="X Amplitude" />
                        <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding AmplitudeXVoltage, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="11" Text="Y Amplitude" />
                        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding AmplitudeYVoltage, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="12" Text="X Feedback Scale" />
                        <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding XFeedbackScale, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="13" Text="Y Feedback Scale" />
                        <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding YFeedbackScale, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="14" Text="Fill Fraction" />
                        <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding FillFraction, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="15" Text="Retrace Ratio" />
                        <TextBox Grid.Row="15" Grid.Column="1" Text="{Binding RetraceRatio, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="16" Text="Bidi Phase Samples" />
                        <TextBox Grid.Row="16" Grid.Column="1" Text="{Binding BidirectionalPhaseSamples, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="17" Text="Detector Offset Samples" />
                        <TextBox Grid.Row="17" Grid.Column="1" Text="{Binding DetectorOffsetSamples, UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Safety">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Slew Limit" />
                        <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding EnableSlewLimit}" />
                        <TextBlock Grid.Row="1" Text="Max Slew V/s" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxSlewRateVoltsPerSecond, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="2" Text="Ramp ms" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RampMilliseconds, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="3" Text="Demo mode" />
                        <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding UseDemo}" />
                        <TextBlock Grid.Row="4" Text="Samples / Frame" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EstimatedPlanText}" Foreground="#A9BDCE" FontWeight="SemiBold" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#A9BDCE"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Apply / Save" Command="{Binding ApplyCommand}" />
                <Button Content="Demo Preview" Command="{Binding DemoPreviewCommand}" />
                <Button Content="Run" Command="{Binding RunCommand}" />
                <Button Content="Stop" Command="{Binding StopCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
