<UserControl x:Class="MetaView.Presentation.Views.HardwarePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MetaView.Presentation.Controls">
    <UserControl.Resources>
        <Style x:Key="StageStepTrackButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="20"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StageStepThumb" TargetType="Thumb">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Width="9"
                                Height="20"
                                Background="#5A9BC8"
                                BorderBrush="#92C7E8"
                                BorderThickness="1"
                                CornerRadius="3"
                                Opacity="0.88" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StageStepSlider" TargetType="Slider">
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Border Background="#121B23"
                                BorderBrush="#294256"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Border BorderBrush="#22FFFFFF"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="3"
                                        Opacity="0.12" />
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                      Background="#1B405E"
                                                      Style="{StaticResource StageStepTrackButton}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                      Background="Transparent"
                                                      Style="{StaticResource StageStepTrackButton}" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource StageStepThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StageRingButton" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter x:Name="Presenter"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Presenter" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Presenter" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StageRingSegmentPath" TargetType="Path">
            <Setter Property="Fill" Value="#22313A" />
            <Setter Property="Stroke" Value="#263E51" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="Opacity" Value="0.94" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="#315E7A" />
                    <Setter Property="Stroke" Value="#82CFFF" />
                    <Setter Property="StrokeThickness" Value="2.2" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#58B9FF"
                                              BlurRadius="10"
                                              ShadowDepth="0"
                                              Opacity="0.35" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="#182832" />
                    <Setter Property="Stroke" Value="#B9E6FF" />
                    <Setter Property="StrokeThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StageStopButton" TargetType="Button">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="StopFace"
                                     Stroke="#FF665A"
                                     StrokeThickness="1.2">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#F36A61" Offset="0" />
                                        <GradientStop Color="#BD1F23" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Margin="5"
                                     Stroke="#FFFFFF"
                                     StrokeThickness="1"
                                     Opacity="0.16" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StopFace" Property="Stroke" Value="#FFB3A8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StopFace" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightPathSegmentButton" TargetType="RadioButton">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome"
                                Background="#151F28"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border BorderBrush="#28FFFFFF"
                                        BorderThickness="1,1,0,0"
                                        CornerRadius="2"
                                        Opacity="0.06" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#365A74" />
                                <Setter TargetName="Chrome" Property="Background" Value="#182836" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#28536F" Offset="0" />
                                            <GradientStop Color="#1D4564" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5FA8DD" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AdvancedScanExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="#111A22"
                                BorderBrush="#29455C"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderToggle"
                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Content="{TemplateBinding Header}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="8,6"
                                              HorizontalContentAlignment="Stretch"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="HeaderChrome"
                                                    Background="Transparent"
                                                    CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Left"
                                                            Width="18"
                                                            Height="18"
                                                            Background="#182631"
                                                            BorderBrush="#203343"
                                                            BorderThickness="1"
                                                            CornerRadius="9"
                                                            Margin="0,0,7,0">
                                                        <Path x:Name="Chevron"
                                                              Width="8"
                                                              Height="5"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Fill="#9DB4C5"
                                                              Data="M 0 0 L 4 5 L 8 0 Z" />
                                                    </Border>
                                                    <ContentPresenter ContentSource="Content"
                                                                      VerticalAlignment="Center" />
                                                </DockPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderChrome" Property="Background" Value="#152331" />
                                                    <Setter TargetName="Chevron" Property="Fill" Value="#DDEBFA" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Chevron" Property="Data" Value="M 0 5 L 4 0 L 8 5 Z" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Border x:Name="ContentSite"
                                        BorderBrush="#263E52"
                                        BorderThickness="0,1,0,0"
                                        Padding="8,8,8,10"
                                        Visibility="Collapsed">
                                    <ContentPresenter ContentSource="Content" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorder}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BrushHeaderChrome}" BorderBrush="{StaticResource BrushLine}" BorderThickness="0,0,0,1" Padding="10,0" Height="36">
                <DockPanel LastChildFill="False">
                    <Grid DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="3" Height="22" Background="#5AAEFF" CornerRadius="2" Opacity="0.9" />
                        <TextBlock Grid.Column="1"
                                   Text="Device Controls"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="6">
                <StackPanel>
                        <StackPanel DataContext="{Binding Scan}">
                            <Border Style="{StaticResource SubtlePanel}" Margin="0,0,0,8">
                                <StackPanel>
                                    <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                        <TextBlock Text="Image Settings" Style="{StaticResource AreaTitle}" Margin="0,0,0,0" />
                                    </DockPanel>

                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,6,0">
                                            <TextBlock Text="Zoom" Style="{StaticResource FieldLabel}" />
                                            <ComboBox ItemsSource="{Binding ZoomOptions}" SelectedItem="{Binding Zoom}" />
                                        </StackPanel>
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Image Size" Style="{StaticResource FieldLabel}" />
                                            <ComboBox IsEditable="True" Text="800 x 800">
                                                <ComboBoxItem Content="200 x 200" />
                                                <ComboBoxItem Content="512 x 512" />
                                                <ComboBoxItem Content="800 x 800" />
                                                <ComboBoxItem Content="1024 x 1024" />
                                                <ComboBoxItem Content="Custom" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,6,0">
                                            <TextBlock Text="Capture" Style="{StaticResource FieldLabel}" />
                                            <controls:NumericStepper Value="{Binding Captures, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="999" Step="1" DecimalPlaces="0" />
                                        </StackPanel>
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Average" Style="{StaticResource FieldLabel}" />
                                            <controls:NumericStepper Value="{Binding Average, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="64" Step="1" DecimalPlaces="0" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,6,0">
                                            <TextBlock Text="Offset (X / Y)" Style="{StaticResource FieldLabel}" />
                                            <ComboBox IsEditable="True" Text="0 / 0">
                                                <ComboBoxItem Content="0 / 0" />
                                                <ComboBoxItem Content="10 / 0" />
                                                <ComboBoxItem Content="0 / 10" />
                                                <ComboBoxItem Content="-10 / 0" />
                                                <ComboBoxItem Content="Custom" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Objective" Style="{StaticResource FieldLabel}" />
                                            <ComboBox SelectedIndex="1">
                                                <ComboBoxItem Content="10x / 0.40 DRY" />
                                                <ComboBoxItem Content="20x / 0.75" />
                                                <ComboBoxItem Content="40x / 1.10 W" />
                                                <ComboBoxItem Content="60x / 1.20 W" />
                                            </ComboBox>
                                        </StackPanel>
                                    </UniformGrid>

                                    <Expander IsExpanded="False" Margin="0,4,0,0" Style="{StaticResource AdvancedScanExpander}">
                                        <Expander.Header>
                                            <TextBlock TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding DwellTimeUs}" Foreground="{StaticResource BrushMuted}" />
                                                <Run Text=" us \ Round-Trip \ " Foreground="{StaticResource BrushMuted}" />
                                                <Run Text="{Binding LineSpeedHz}" Foreground="{StaticResource BrushMuted}" />
                                                <Run Text=" Hz \ 0.022 \ " Foreground="{StaticResource BrushMuted}" />
                                                <Run Text="{Binding Shutter}" Foreground="{StaticResource BrushMuted}" />
                                            </TextBlock>
                                        </Expander.Header>
                                        <StackPanel>
                                            <UniformGrid Columns="2">
                                                <StackPanel Margin="0,0,6,0">
                                                    <TextBlock Text="Dwell (us)" Style="{StaticResource FieldLabel}" />
                                                    <controls:NumericStepper Value="{Binding DwellTimeUs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0.1" Maximum="100" Step="0.1" DecimalPlaces="1" Unit="us" />
                                                </StackPanel>
                                                <StackPanel Margin="6,0,0,0">
                                                    <TextBlock Text="Step (V)" Style="{StaticResource FieldLabel}" />
                                                    <controls:NumericStepper Value="0.022" Minimum="0.001" Maximum="1" Step="0.001" DecimalPlaces="3" Unit="V" />
                                                </StackPanel>
                                            </UniformGrid>

                                            <TextBlock Text="Scan Mode" Style="{StaticResource FieldLabel}" />
                                            <UniformGrid Columns="2" Margin="0,2,0,8">
                                                <RadioButton Content="One-Way" />
                                                <RadioButton Content="Round-Trip" IsChecked="True" />
                                            </UniformGrid>

                                            <UniformGrid Columns="2">
                                                <StackPanel Margin="0,0,6,0">
                                                    <TextBlock Text="Line Speed (Hz)" Style="{StaticResource FieldLabel}" />
                                                    <ComboBox Text="{Binding LineSpeedHz}">
                                                        <ComboBoxItem Content="200" />
                                                        <ComboBoxItem Content="500" />
                                                        <ComboBoxItem Content="1000" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Margin="6,0,0,0">
                                                    <TextBlock Text="Shutter" Style="{StaticResource FieldLabel}" />
                                                    <ComboBox Text="{Binding Shutter}">
                                                        <ComboBoxItem Content="Standard" />
                                                        <ComboBoxItem Content="Sample protection" />
                                                        <ComboBoxItem Content="Always Open" />
                                                        <ComboBoxItem Content="Always Closed" />
                                                    </ComboBox>
                                                </StackPanel>
                                            </UniformGrid>

                                            <Button Content="Reload Zoom Factor" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <StackPanel DataContext="{Binding Hardware}">
                            <Border Style="{StaticResource SubtlePanel}" Margin="0,0,0,8">
                                <StackPanel>
                                    <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                        <TextBlock Text="Stage Motion" Style="{StaticResource AreaTitle}" Margin="0,0,0,0" />
                                    </DockPanel>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="XY Step" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                                        <Grid Grid.Column="1">
                                            <Slider Style="{StaticResource StageStepSlider}"
                                                    Minimum="1"
                                                    Maximum="50"
                                                    Value="{Binding XyStep, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="{Binding XyStep, StringFormat={}{0:0.00} mm}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       IsHitTestVisible="False" />
                                        </Grid>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Z Step" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                                        <Grid Grid.Column="1">
                                            <Slider Style="{StaticResource StageStepSlider}"
                                                    Minimum="0.1"
                                                    Maximum="5"
                                                    Value="{Binding ZStep, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="{Binding ZStep, StringFormat={}{0:0.##} mm}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       IsHitTestVisible="False" />
                                        </Grid>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="58" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <Button Content="Save" Command="{Binding SavePositionCommand}" Style="{StaticResource MotionButton}" Margin="0,0,0,5" />
                                            <Button Content="Pos" Command="{Binding MoveToSavedPositionCommand}" Style="{StaticResource MotionButton}" Margin="0,0,0,5" />
                                            <Button Content="Unload" Command="{Binding UnloadCommand}" Style="{StaticResource MotionButton}" Margin="0" />
                                        </StackPanel>

                                        <Grid Grid.Column="1" Width="166" Height="166" HorizontalAlignment="Center" Margin="10,0">
                                            <Ellipse Width="84"
                                                     Height="84"
                                                     Fill="#17242D"
                                                     Stroke="{StaticResource BrushLine}"
                                                     StrokeThickness="1"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />

                                            <Button Command="{Binding MoveYPositiveCommand}" Style="{StaticResource StageRingButton}">
                                                <Path Data="M 33,33 A 72,72 0 0 1 133,33 L 108,58 A 37,37 0 0 0 58,58 Z"
                                                      Style="{StaticResource StageRingSegmentPath}" />
                                            </Button>
                                            <Button Command="{Binding MoveXPositiveCommand}" Style="{StaticResource StageRingButton}">
                                                <Path Data="M 133,33 A 72,72 0 0 1 133,133 L 108,108 A 37,37 0 0 0 108,58 Z"
                                                      Style="{StaticResource StageRingSegmentPath}" />
                                            </Button>
                                            <Button Command="{Binding MoveYNegativeCommand}" Style="{StaticResource StageRingButton}">
                                                <Path Data="M 133,133 A 72,72 0 0 1 33,133 L 58,108 A 37,37 0 0 0 108,108 Z"
                                                      Style="{StaticResource StageRingSegmentPath}" />
                                            </Button>
                                            <Button Command="{Binding MoveXNegativeCommand}" Style="{StaticResource StageRingButton}">
                                                <Path Data="M 33,133 A 72,72 0 0 1 33,33 L 58,58 A 37,37 0 0 0 58,108 Z"
                                                      Style="{StaticResource StageRingSegmentPath}" />
                                            </Button>

                                            <TextBlock Text="Y+"
                                                       Foreground="{StaticResource BrushText}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Top"
                                                       Margin="0,26,0,0"
                                                       IsHitTestVisible="False" />
                                            <TextBlock Text="X+"
                                                       Foreground="{StaticResource BrushText}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,24,0"
                                                       IsHitTestVisible="False" />
                                            <TextBlock Text="Y-"
                                                       Foreground="{StaticResource BrushText}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Bottom"
                                                       Margin="0,0,0,24"
                                                       IsHitTestVisible="False" />
                                            <TextBlock Text="X-"
                                                       Foreground="{StaticResource BrushText}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Margin="24,0,0,0"
                                                       IsHitTestVisible="False" />

                                            <Button Content="STOP"
                                                    Style="{StaticResource StageStopButton}"
                                                    Command="{Binding StopCommand}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                        </Grid>

                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Button Grid.Row="0" Command="{Binding MoveZPositiveCommand}" Style="{StaticResource MotionButton}" Margin="0,0,0,5">
                                                <Path Width="14" Height="10" Stretch="Fill" Fill="{StaticResource BrushText}" Data="M 0 10 L 7 0 L 14 10 Z" />
                                            </Button>
                                            <Button Grid.Row="2" Command="{Binding MoveZNegativeCommand}" Style="{StaticResource MotionButton}">
                                                <Path Width="14" Height="10" Stretch="Fill" Fill="{StaticResource BrushText}" Data="M 0 0 L 7 10 L 14 0 Z" />
                                            </Button>
                                        </Grid>
                                    </Grid>

                                    <Border Style="{StaticResource ReadoutPanel}">
                                        <UniformGrid Columns="3">
                                            <StackPanel>
                                                <TextBlock Text="X" Style="{StaticResource HudLabel}" />
                                                <TextBlock Text="{Binding X, StringFormat={}{0:0.00} mm}" Style="{StaticResource HudValue}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Y" Style="{StaticResource HudLabel}" />
                                                <TextBlock Text="{Binding Y, StringFormat={}{0:0.00} mm}" Style="{StaticResource HudValue}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Z" Style="{StaticResource HudLabel}" />
                                                <TextBlock Text="{Binding Z, StringFormat={}{0:0.00} mm}" Style="{StaticResource HudValue}" />
                                            </StackPanel>
                                        </UniformGrid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <Border Style="{StaticResource SubtlePanel}">
                                <StackPanel>
                                    <TextBlock Text="Light Path" Style="{StaticResource AreaTitle}" />
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="86" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Upper Mirror" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                Background="#101820"
                                                BorderBrush="#203242"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="1" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <RadioButton Content="Brightfield"
                                                             GroupName="UpperMirror"
                                                             Style="{StaticResource LightPathSegmentButton}" />
                                                <Border Grid.Column="1" Background="#1B2D3A" Margin="0,4" />
                                                <RadioButton Grid.Column="2"
                                                             Content="Laser Scan"
                                                             GroupName="UpperMirror"
                                                             IsChecked="True"
                                                             Style="{StaticResource LightPathSegmentButton}" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="86" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Lower Mirror" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                Background="#101820"
                                                BorderBrush="#203242"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="1" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <RadioButton Content="Epi"
                                                             GroupName="LowerMirror"
                                                             Style="{StaticResource LightPathSegmentButton}" />
                                                <Border Grid.Column="1" Background="#1B2D3A" Margin="0,4" />
                                                <RadioButton Grid.Column="2"
                                                             Content="Fwd"
                                                             GroupName="LowerMirror"
                                                             IsChecked="True"
                                                             Style="{StaticResource LightPathSegmentButton}" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Background="#101820"
                                            BorderBrush="#203242"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="9,7">
