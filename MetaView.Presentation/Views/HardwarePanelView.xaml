                                                BorderBrush="#1E2D38"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="6">
                                            <Viewbox Height="220" Stretch="Uniform">
                                                <Canvas Width="420" Height="300">
                                                    <Canvas.Resources>
                                                        <Style x:Key="LightPathBeam" TargetType="Line">
                                                            <Setter Property="Stroke" Value="#9EDFFF" />
                                                            <Setter Property="StrokeThickness" Value="5" />
                                                            <Setter Property="StrokeStartLineCap" Value="Square" />
                                                            <Setter Property="StrokeEndLineCap" Value="Square" />
                                                        </Style>
                                                        <Style x:Key="LightPathOptic" TargetType="Line">
                                                            <Setter Property="Stroke" Value="#B9E6FF" />
                                                            <Setter Property="StrokeThickness" Value="6" />
                                                            <Setter Property="StrokeStartLineCap" Value="Square" />
                                                            <Setter Property="StrokeEndLineCap" Value="Square" />
                                                        </Style>
                                                    </Canvas.Resources>

                                                    <Ellipse Width="36" Height="36" Canvas.Left="18" Canvas.Top="54" Stroke="#00A8E8" StrokeThickness="5" Fill="Transparent" />
                                                    <Line X1="36" Y1="36" X2="36" Y2="108" Stroke="#00A8E8" StrokeThickness="4" />
                                                    <Line X1="0" Y1="72" X2="72" Y2="72" Stroke="#00A8E8" StrokeThickness="4" />
                                                    <Line X1="11" Y1="47" X2="61" Y2="97" Stroke="#00A8E8" StrokeThickness="4" />
                                                    <Line X1="61" Y1="47" X2="11" Y2="97" Stroke="#00A8E8" StrokeThickness="4" />
                                                    <Line X1="72" Y1="72" X2="132" Y2="72" Style="{StaticResource LightPathBeam}" />
                                                    <Line X1="150" Y1="100" X2="190" Y2="45" Style="{StaticResource LightPathOptic}" />
                                                    <Line X1="210" Y1="72" X2="250" Y2="72" Style="{StaticResource LightPathBeam}" />
                                                    <Rectangle Width="9" Height="62" Canvas.Left="245" Canvas.Top="40" Fill="#1976B8" />
                                                    <Rectangle Width="9" Height="10" Canvas.Left="245" Canvas.Top="66" Fill="#9EDFFF" Opacity="0.65" />
                                                    <Line X1="256" Y1="72" X2="305" Y2="72" Style="{StaticResource LightPathBeam}" />
                                                    <Line X1="318" Y1="100" X2="358" Y2="45" Style="{StaticResource LightPathOptic}" />
                                                    <Line X1="358" Y1="100" X2="330" Y2="137" Style="{StaticResource LightPathBeam}" Opacity="0.65" />
                                                    <Border Canvas.Left="310" Canvas.Top="136" Width="42" Height="42" Background="#6C6C6C" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="2">
                                                        <TextBlock Text="10X" Foreground="White" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <Rectangle Width="34" Height="8" Canvas.Left="314" Canvas.Top="178" Fill="#9A9A9A" />
                                                    <Rectangle Width="30" Height="5" Canvas.Left="316" Canvas.Top="186" Fill="#666666" />
                                                    <Line X1="330" Y1="204" X2="390" Y2="204" Style="{StaticResource LightPathBeam}" />
                                                    <Ellipse Width="40" Height="40" Canvas.Left="365" Canvas.Top="225" Stroke="#D5DCE0" StrokeThickness="2" Fill="Transparent" />
                                                    <Ellipse Width="24" Height="24" Canvas.Left="373" Canvas.Top="233" Stroke="#D5DCE0" StrokeThickness="2" Fill="Transparent" />
                                                    <Line X1="385" Y1="221" X2="385" Y2="269" Stroke="#D5DCE0" StrokeThickness="1" />
                                                    <Line X1="361" Y1="245" X2="409" Y2="245" Stroke="#D5DCE0" StrokeThickness="1" />
                                                    <Line X1="368" Y1="228" X2="402" Y2="262" Stroke="#D5DCE0" StrokeThickness="1" />
                                                    <Line X1="402" Y1="228" X2="368" Y2="262" Stroke="#D5DCE0" StrokeThickness="1" />
                                                    <TextBlock Text="PD" Canvas.Left="376" Canvas.Top="265" Foreground="#D5DCE0" FontSize="15" FontWeight="SemiBold" />
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>



