                                            <TextBlock>
                                                <Run Text="Path  " Foreground="{StaticResource BrushMuted}" />
                                                <Run Text="Laser Scan" FontWeight="SemiBold" />
                                                <Run Text="  /  " Foreground="{StaticResource BrushMuted}" />
                                                <Run Text="Fwd" FontWeight="SemiBold" />
                                            </TextBlock>
                                        </DockPanel>
                                    </Border>

