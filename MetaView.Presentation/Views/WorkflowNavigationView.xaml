<UserControl x:Class="MetaView.Presentation.Views.WorkflowNavigationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PanelBorder}" Padding="12">
        <StackPanel>
            <TextBlock Text="WORKFLOW" Style="{StaticResource FieldLabel}" Margin="4,0,0,8" />

            <Border Style="{StaticResource WorkflowStepActive}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="3" Background="#1E3A50" BorderBrush="{StaticResource BrushCyan}" BorderThickness="1">
                        <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Device Preflight" FontWeight="SemiBold" />
                        <TextBlock Text="Laser / Stage / Storage" Foreground="{StaticResource BrushMuted}" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource WorkflowStep}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="3" Background="#202B34" BorderBrush="#365876" BorderThickness="1">
                        <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Technique &amp; Mode" FontWeight="SemiBold" />
                        <TextBlock Text="SRS / TPEF / DC" Foreground="{StaticResource BrushMuted}" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource WorkflowStep}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="3" Background="#202B34" BorderBrush="#365876" BorderThickness="1">
                        <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Live Tuning" FontWeight="SemiBold" />
                        <TextBlock Text="Focus / Gain / Power" Foreground="{StaticResource BrushMuted}" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource WorkflowStep}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="3" Background="#202B34" BorderBrush="#365876" BorderThickness="1">
                        <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Signal Check" FontWeight="SemiBold" />
                        <TextBlock Text="ROI / Histogram / SNR" Foreground="{StaticResource BrushMuted}" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource WorkflowStep}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="3" Background="#202B34" BorderBrush="#365876" BorderThickness="1">
                        <TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Acquisition" FontWeight="SemiBold" />
                        <TextBlock Text="Capture / Large Area / 3D" Foreground="{StaticResource BrushMuted}" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="SYSTEM" Style="{StaticResource FieldLabel}" Margin="4,18,0,8" />
            <Button Content="Device Center" />
            <Button Content="Calibration" />
            <Button Content="Log Viewer" />
            <Button Content="Diagnostics" />
        </StackPanel>
    </Border>
</UserControl>


