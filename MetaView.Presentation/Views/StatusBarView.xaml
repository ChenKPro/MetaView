<UserControl x:Class="MetaView.Presentation.Views.StatusBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="#2D4A63" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Padding="12,0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#243543" Offset="0" />
                <GradientStop Color="#1D2B36" Offset="0.58" />
                <GradientStop Color="#151F28" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="7" Direction="90" ShadowDepth="1" Opacity="0.16" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="0.75*" />
                <ColumnDefinition Width="0.75*" />
                <ColumnDefinition Width="0.9*" />
                <ColumnDefinition Width="0.8*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource StatusSegment}">
                <TextBlock>
                    <Run Text="Stage " FontWeight="Bold" />
                    <Run Text="X: 4892.67 um | Y: -630.24 um | Z: 22921.2 um" Foreground="{StaticResource BrushMuted}" />
                </TextBlock>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatusSegment}">
                <TextBlock>
                    <Run Text="Task " FontWeight="Bold" />
                    <Run Text="{Binding State}" Foreground="{StaticResource BrushMuted}" />
                </TextBlock>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatusSegment}">
                <TextBlock>
                    <Run Text="Disk " FontWeight="Bold" />
                    <Run Text="328 GB Free" Foreground="{StaticResource BrushMuted}" />
                </TextBlock>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatusSegment}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Memory" FontWeight="Bold" VerticalAlignment="Center" />
                    <ProgressBar Grid.Column="1" Height="6" Value="62" Maximum="100" Margin="10,0" Foreground="{StaticResource BrushCyan}" />
                    <TextBlock Grid.Column="2" Text="62%" Foreground="{StaticResource BrushMuted}" VerticalAlignment="Center" />
                </Grid>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource StatusSegment}">
                <TextBlock>
                    <Run Text="Log " FontWeight="Bold" />
                    <Run Text="0 Warning" Foreground="{StaticResource BrushMuted}" />
                </TextBlock>
            </Border>
            <Border Grid.Column="5" Style="{StaticResource StatusSegment}">
                <TextBlock>
                    <Run Text="Latest " FontWeight="Bold" />
                    <Run Text="{Binding Message}" Foreground="{StaticResource BrushMuted}" />
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</UserControl>



