<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ImageViewer2D.Controls">

    <Style x:Key="ImageViewerToolButton" TargetType="{x:Type ToggleButton}">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="0,0,0,5" />
        <Setter Property="Foreground" Value="#D7E6F2" />
        <Setter Property="Background" Value="#263540" />
        <Setter Property="BorderBrush" Value="#40576A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#314756" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#6BA8D6" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#2E78AA" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#76C7FF" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:ImageViewer2D}">
        <Setter Property="Background" Value="#111418" />
        <Setter Property="BorderBrush" Value="#2A2F36" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ImageViewer2D}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid ClipToBounds="True">
                            <Canvas x:Name="PART_Surface"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    Focusable="True">
                                <Image x:Name="PART_Image"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True" />
                                <Canvas x:Name="PART_RoiCanvas"
                                        IsHitTestVisible="False" />
                                <Canvas x:Name="PART_CrosshairCanvas"
                                        IsHitTestVisible="False" />
                            </Canvas>

                            <Border x:Name="PART_ToolBar"
                                    Width="42"
                                    Margin="10"
                                    Padding="5"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#CC15191F"
                                    BorderBrush="#778A96A3"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <StackPanel>
                                    <ToggleButton x:Name="PART_PanTool"
                                                  Content="↕"
                                                  ToolTip="Pan"
                                                  Style="{StaticResource ImageViewerToolButton}" />
                                    <ToggleButton x:Name="PART_SelectTool"
                                                  Content="↖"
                                                  ToolTip="Select ROI"
                                                  Style="{StaticResource ImageViewerToolButton}" />
                                    <ToggleButton x:Name="PART_RectangleTool"
                                                  Content="□"
                                                  ToolTip="Rectangle ROI"
                                                  Style="{StaticResource ImageViewerToolButton}" />
                                    <ToggleButton x:Name="PART_EllipseTool"
                                                  Content="○"
                                                  ToolTip="Ellipse ROI"
                                                  Style="{StaticResource ImageViewerToolButton}" />
                                    <ToggleButton x:Name="PART_CrosshairTool"
                                                  Content="+"
                                                  ToolTip="Crosshair"
                                                  Style="{StaticResource ImageViewerToolButton}" />
                                    <Rectangle Height="1"
                                               Margin="2,1,2,6"
                                               Fill="#40576A"
                                               Opacity="0.9" />
                                    <ToggleButton x:Name="PART_ClearRoisTool"
                                                  Content="×"
                                                  ToolTip="Clear ROI and crosshair"
                                                  Margin="0"
                                                  Style="{StaticResource ImageViewerToolButton}" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="PART_Navigator"
                                    Width="188"
                                    Height="128"
                                    Margin="10"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Background="#CC15191F"
                                    BorderBrush="#778A96A3"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <Canvas x:Name="PART_NavigatorCanvas"
                                        Width="180"
                                        Height="120"
                                        Margin="4"
                                        Background="Transparent"
                                        ClipToBounds="True">
                                    <Image x:Name="PART_NavigatorImage"
                                           RenderOptions.BitmapScalingMode="LowQuality" />
                                    <Rectangle x:Name="PART_NavigatorViewport"
                                               Stroke="#FFFFD166"
                                               StrokeThickness="1.5"
                                               Fill="#22FFD166" />
                                </Canvas>
                            </Border>

                            <Border Margin="10"
                                    Padding="8,4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Background="#AA000000"
                                    CornerRadius="3">
                                <TextBlock x:Name="PART_StatusText"
                                           Foreground="#F5F7FA"
                                           FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
